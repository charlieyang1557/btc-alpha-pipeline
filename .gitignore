# Data files (too large for git)
data/raw/*.parquet
data/raw/archive/*.parquet
data/features/*.parquet

# Quality reports (generated)
data/quality/*.json

# Trade log CSVs (generated per run)
data/results/

# Compiled-strategy manifests (regenerable from DSL + compiler git SHA;
# scales to thousands per funnel run; ManifestDriftError detects drift
# from on-disk-vs-regen, not from commit history)
data/compiled_strategies/

# SQLite databases (widened to cover WAL/SHM journals)
backtest/experiments.db
agents/spend_ledger.db*

# Raw API payloads (per-run artifacts, not source)
raw_payloads/

# Dry-run artifacts (physically isolated; never production)
dryrun_payloads/
ledger_dryrun.db

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Secrets
.env

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
data/features/
.Rhistory
