# Copy this file to .env and fill in local secrets.
# Never commit real API keys or webhook URLs.

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Discord webhook for long-task-completion ping (per feedback_long_task_pings.md memory).
# Created at Discord Server Settings → Integrations → Webhooks; rotate immediately if leaked.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<webhook_id>/<webhook_token>
